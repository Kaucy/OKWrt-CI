mtk: mt_wifi: guard SAE cleanup in AP-only builds

The 7.6.7.3 AP source calls an SAE helper even when DOT11_SAE_SUPPORT is
disabled, while SAE_CFG is only present when SAE support is compiled.  Its
interface close path also declares pAd only for combined AP+STA builds even
though the AP-only body always uses it.  The AP ioctl and MBSS interface
implementations also comment out the central driver header despite directly
using RTMP adapter, channel and wifi_dev definitions.  Finally, its
authentication flood check leaves an else-closing brace and an 802.11r field
access active when SAE and FT are disabled.  Keep these paths consistent with
the selected feature guards and include the complete driver declarations.

--- a/mt_wifi/os/linux/ap_ioctl.c
+++ b/mt_wifi/os/linux/ap_ioctl.c
@@ -28 +28 @@
-/*#include "rt_config.h" */
+#include "rt_config.h"

--- a/mt_wifi/embedded/ap/ap_mbss_inf.c
+++ b/mt_wifi/embedded/ap/ap_mbss_inf.c
@@ -46 +46 @@
-/*#include "rt_config.h" */
+#include "rt_config.h"

--- a/mt_wifi/embedded/ap/ap.c
+++ b/mt_wifi/embedded/ap/ap.c
@@ -3711,7 +3711,9 @@ VOID MacTableMaintenance(RTMP_ADAPTER *pAd)
 				NdisZeroMemory(pMbss->wdev.WscControl.EntryAddr, MAC_ADDR_LEN);
 
 #endif /* WSC_AP_SUPPORT */
+#if defined(DOT11_SAE_SUPPORT) || defined(SUPP_SAE_SUPPORT)
 				delete_saeinstance_entry(&pAd->SaeCfg, pEntry);
+#endif
 				mac_entry_delete(pAd, pEntry);
 			continue;
 		} else {
@@ -7704,9 +7706,7 @@ INT ap_inf_open(struct wifi_dev *wdev)
 */
 INT ap_inf_close(struct wifi_dev *wdev)
 {
-#if defined(CONFIG_AP_SUPPORT) && defined(CONFIG_STA_SUPPORT)
 	struct _RTMP_ADAPTER *pAd = (struct _RTMP_ADAPTER *)wdev->sys_handle;
-#endif	/* CONFIG_AP_SUPPORT && CONFIG_STA_SUPPORT */
 
 	if (!wdev->state)
 		return TRUE;

--- a/mt_wifi/embedded/fsm/ap_mgmt_auth.c
+++ b/mt_wifi/embedded/fsm/ap_mgmt_auth.c
@@ -701,19 +701,24 @@
 #ifdef DOT11R_FT_SUPPORT
 				}
 #endif
-			} else {
-#endif //DOT11_SAE_SUPPORT
+			} else
+#endif /* DOT11_SAE_SUPPORT */
+			{
 			if ((IS_AKM_WPA2_SHA256(AkmMap) || IS_AKM_WPA2PSK_SHA256(AkmMap)) &&
 				pEntry->SecConfig.ft_only == FALSE) {
+#ifdef DOT11R_FT_SUPPORT
 				if (!wdev->FtCfg.FtCapFlag.Dot11rFtEnable) {
+#endif
 					if ((pAuth_info->auth_alg == AUTH_MODE_FT) ||
 						(pAuth_info->auth_alg == AUTH_MODE_SAE) ||
 						(pAuth_info->auth_alg == AUTH_MODE_KEY) ||
 						(pAuth_info->auth_alg == AUTH_MODE_FILS) ||
 						(pAuth_info->auth_alg == AUTH_MODE_FILS_PFS))
 						goto auth_failure;
+#ifdef DOT11R_FT_SUPPORT
 				}
-			}
+#endif
+			}
 			}
 		}
 #endif /* DOT11W_PMF_SUPPORT */
