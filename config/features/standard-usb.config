CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_smartmontools=y
CONFIG_PACKAGE_hd-idle=y
CONFIG_PACKAGE_luci-app-qmodem=y
# QModem defaults to its out-of-tree vendor QMI drivers.  They do not build on
# every current kernel and, on Qualcomm Pro, also make NSS ECM expect an rmnet
# NSS provider that the selected feed does not ship.  The in-tree generic QMI
# driver keeps modem support without either unsupported dependency.
CONFIG_PACKAGE_luci-app-qmodem_INCLUDE_generic-qmi-wwan=y
# CONFIG_PACKAGE_luci-app-qmodem_INCLUDE_vendor-qmi-wwan is not set
# CONFIG_PACKAGE_luci-app-qmodem_INCLUDE_nss-qmi-wwan is not set
