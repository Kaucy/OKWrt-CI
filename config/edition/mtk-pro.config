CONFIG_MTK_MT_WIFI=m
CONFIG_PACKAGE_kmod-mt_wifi=y
# These are tristate Kbuild selectors for an external module.  Setting them to
# built-in makes the external-module build run an empty MODPOST; upstream's
# MT7986 defconfig therefore selects all three as modules.
CONFIG_MTK_WIFI_MODE_AP=m
CONFIG_MTK_MT_AP_SUPPORT=m
# The vendor sources reference RRM request types from the AP implementation.
CONFIG_MTK_DOT11K_RRM_SUPPORT=y
# APCLI is enabled by the vendor defaults even for AP-only images. In this
# driver snapshot it calls native SAE helpers without enabling the matching
# SAE data structures, so keep this edition strictly AP-only. Native vendor
# WPA3 has a separate broken include order; userspace hostapd still provides
# WPA3 without either option.
# CONFIG_MTK_APCLI_SUPPORT is not set
# CONFIG_MTK_WPA3_SUPPORT is not set
CONFIG_PACKAGE_kmod-mediatek_hnat=y
# The vendor HNAT Kconfig symbol depends on IP_NF_NAT. Without this package
# OpenWrt accepts kmod-mediatek_hnat but generates an empty package, leaving
# WARP's ra_sw_nat_hook_tx reference unresolved at modpost.
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-warp=y
CONFIG_PACKAGE_mtwifi-cfg-ucode=y
CONFIG_PACKAGE_luci-app-mtwifi-cfg=y
